{
  "name": "mangatrack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next dev --turbopack",
    "dev:normal": "next dev --turbopack",
    "build": "next build --turbopack",
    "build:full": "npm run typecheck && next build --no-lint",
    "build:test": "dotenv -e .env.test -- next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "start:test": "dotenv -e .env.test -- next start",
    "start-server": "echo '🚀 Starting MangaTrack server...' && echo '🌐 Server will be available at http://localhost:3000' && echo '📱 Press Ctrl+C to stop the server' && echo '' && next start",
    "build:start": "npm run build && npm run start-server",
    "build:start:test": "npm run build:test && npm run start:test",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:coverage": "node scripts/coverage.js",
    "test:e2e:coverage:headed": "playwright test --project=chromium-coverage --headed",
    "coverage:report": "playwright show-report"
  },
  "dependencies": {
    "@clerk/backend": "^2.18.3",
    "@clerk/nextjs": "^6.33.3",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@stripe/stripe-js": "^8.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "jest": "^30.2.0",
    "lucide-react": "^0.545.0",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "prisma": "^6.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "resend": "^6.1.3",
    "sonner": "^2.0.7",
    "stripe": "^19.1.0",
    "svix": "^1.77.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.29.4",
    "tailwind-merge": "^3.3.1",
    "ts-jest": "^29.4.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@clerk/testing": "^1.13.7",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
