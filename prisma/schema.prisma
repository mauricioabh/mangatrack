generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(cuid())
  clerkId            String           @unique
  email              String           @unique
  name               String?
  avatar             String?
  tier               UserTier         @default(BASIC)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  emailNotifications Boolean          @default(true)
  notifications      Notification[]
  readingHistory     ReadingHistory[]
  favorites          UserFavorite[]
  pushTokens         UserPushToken[]

  @@map("users")
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  mangaDexId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaDexId])
  @@index([mangaDexId])
  @@index([userId, createdAt])
  @@map("user_favorites")
}

model UserPushToken {
  id        String           @id @default(cuid())
  userId    String
  token     String
  platform  PushTokenPlatform @default(WEB)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("user_push_tokens")
}

enum PushTokenPlatform {
  WEB
  ANDROID
}

model ReadingHistory {
  id            String   @id @default(cuid())
  userId        String
  mangaDexId    String
  chapterDexId  String
  readAt        DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterDexId])
  @@index([userId, mangaDexId])
  @@map("reading_history")
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  message      String
  mangaDexId   String?
  chapterDexId String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum UserTier {
  BASIC
  PREMIUM
}

enum NotificationType {
  NEW_CHAPTER
  MANGA_UPDATE
  SYSTEM
}
