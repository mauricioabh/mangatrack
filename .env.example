# Database (Neon) — rama "dev" en local; rama "main" en Vercel Production
# https://console.neon.tech → mangatrack → Branches → dev → Connection string (pooled)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-XXXX-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Stripe
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_MONTHLY_PRICE_ID=""
STRIPE_PREMIUM_YEARLY_PRICE_ID=""

# Sentry — create project "mangatrack" in org mauricio-barragan (local .env.local only)
SENTRY_DSN=
SENTRY_ORG=mauricio-barragan
SENTRY_PROJECT=mangatrack

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"


# MangaDex API (catalog BFF)
MANGADEX_API_BASE_URL="https://api.mangadex.org"
MANGADEX_CONTENT_RATINGS="safe,suggestive"
MANGADEX_DEFAULT_LOCALE="en"

# Inngest (background jobs / push pipeline)
INNGEST_DEV=1
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Firebase - cliente web (Settings -> activar push). Guia: docs/FIREBASE_SETUP.md
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Firebase - Admin servidor (Inngest envia FCM). Campos del JSON cuenta de servicio
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# MangaDex chapter webhook (optional shared secret)
MANGADEX_WEBHOOK_SECRET=""

# Email Service (Resend)
RESEND_API_KEY="re_..."

PLAYWRIGHT_TEST=false

# Test User Credentials (for testing and development)
TEST_USER_EMAIL="mauricioabh+mangatracktestuser@gmail.com"
TEST_USER_PASSWORD="mangatracktestuser"
